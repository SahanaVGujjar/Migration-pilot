{
  "name": "migration-pilot",
  "version": "1.0.0",
  "description": "Automated Language/Framework Migration Assistant — migrate codebases from JS to TS, React class to hooks, and more.",
  "main": "dist/index.js",
  "bin": {
    "migration-pilot": "./bin/migration-pilot.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "migration",
    "typescript",
    "codemod",
    "refactoring",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "glob": "^10.4.5",
    "ora": "^5.4.1",
    "ts-morph": "^24.0.0",
    "boxen": "^5.1.2",
    "cli-table3": "^0.6.5",
    "figures": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "ts-node": "^10.9.2"
  }
}
