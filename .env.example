# Copy to .env and fill in (never commit .env with real keys)

# Provider: ollama | openrouter | groq | openai
# Profiles: js-to-ts, ts-to-js, class-to-hooks, python-to-java, java-to-python
LLM_PROVIDER=openrouter

# API keys (only set the one matching LLM_PROVIDER)
OPENROUTER_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Optional model override (OpenRouter uses provider/model format)
# LLM_MODEL=openai/gpt-4o-mini

# Optional base URL override
# LLM_BASE_URL=https://openrouter.ai/api/v1

# Development: skip real API calls
# USE_MOCK_AI=true
